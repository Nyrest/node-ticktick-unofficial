{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "typecheck": {
      "dependsOn": [
        "^build",
        "^typecheck"
      ],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    },
    "compile": {
      "dependsOn": [
        "build"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "integration": {
      "dependsOn": [
        "build"
      ],
      "cache": false
    },
    "verify:live": {
      "cache": false
    },
    "cron:register": {
      "cache": false
    },
    "cron:unregister": {
      "cache": false
    }
  }
}
