{
  "name": "ticktick-api-monorepo",
  "private": true,
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "devDependencies": {
    "@types/bun": "latest",
    "turbo": "2.8.21",
    "typescript": "^6.0.2"
  },
  "scripts": {
    "turbo": "turbo",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "build:client": "turbo run build --filter=node-ticktick-unofficial",
    "build:api": "turbo run build --filter=ticktick-unofficial-api",
    "build:cli": "turbo run build --filter=ticktick-unofficial-cli"
  }
}
