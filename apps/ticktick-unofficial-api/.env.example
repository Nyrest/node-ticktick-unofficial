APP_RUNTIME=auto
PORT=3000
HOST=0.0.0.0

TICKTICK_SERVICE=ticktick
TICKTICK_USERNAME=your-account@example.com
TICKTICK_PASSWORD=your-password
TICKTICK_TIMEZONE=Asia/Shanghai
TICKTICK_LANGUAGE=en_US
TICKTICK_SESSION_STORE=auto
TICKTICK_SESSION_FILE=.data/ticktick-session.json

API_AUTH_MODE=none
API_AUTH_TOKEN=change-me

SWAGGER_ENABLED=true
OPENAPI_PATH=/openapi
SWAGGER_PATH=/swagger

SESSION_REFRESH_ENABLED=true
SESSION_REFRESH_CRON=*/30 * * * *
CRON_DRIVER=auto
CRON_SECRET=change-me
BUN_CRON_JOB_NAME=ticktick-unofficial-api-session-refresh
BUN_CRON_SCRIPT=./src/bun-cron.ts

OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS_JSON={}
OTEL_SERVICE_NAME=ticktick-unofficial-api
