{
  "name": "ticktick-unofficial-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Single-user TickTick unofficial API server built with Bun and Elysia.",
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=20"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "typecheck": "tsc --noEmit",
    "build:bun": "bun build ./src/index.ts --target bun --outdir ./dist/bun",
    "build:cloudflare": "bun build ./src/cloudflare.ts --target browser --outdir ./dist/cloudflare",
    "build": "bun run typecheck && bun run build:bun && bun run build:cloudflare",
    "cron:register": "bun src/scripts/register-bun-cron.ts",
    "cron:unregister": "bun src/scripts/unregister-bun-cron.ts"
  },
  "dependencies": {
    "@elysiajs/bearer": "^1.4.3",
    "@elysiajs/cron": "^1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "@elysiajs/opentelemetry": "^1.4.10",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-trace-node": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@upstash/redis": "^1.35.6",
    "elysia": "^1.4.28",
    "ticktick-unofficial": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260327.0",
    "@types/bun": "latest",
    "typescript": "^6.0.2",
    "wrangler": "^4.78.0"
  }
}
